;; On Top — the Core routine schedule.
;;
;; Two-week cycle keyed by category (:digital / :household), then by ISO
;; week-number parity (:week-odd / :week-even), then by weekday.
;; Empty/missing days default to no tasks. A task name is unique within a day.
;; Weekly tasks are duplicated across both weeks (no shared :weekly section).
{:digital
 {:week-odd
  {:monday    ["Gmail inbox"]
   :tuesday   ["Todoist inbox"]
   :wednesday ["Clean Downloads folder" "Clean Desktop folder"]
   :thursday  ["Gmail inbox"]
   :sunday    ["Review calendar (2w back/4w forward)" "Review Waiting for & Package tracking"]}

  :week-even
  {:monday    ["Gmail inbox"]
   :tuesday   ["Physical inbox"]
   :wednesday ["Photo inbox" "Review recent screenshots"]
   :thursday  ["Gmail inbox"]
   :friday    ["Review open tabs on phone"]
   :sunday    ["Review calendar (2w back/4w forward)" "Review Waiting for & Package tracking"]}}

 :household
 {:week-odd
  {:monday    ["Bathroom"]
   :thursday  ["Dust"]
   :sunday    ["Bath towels"]}

  :week-even
  {:wednesday ["Vacuum"]
   :sunday    ["Bath towels"]}}}
