;; On Top — the Core routine schedule.
;;
;; Two-week cycle keyed by category (:digital / :household), then by ISO
;; week-number parity (:week-odd / :week-even), then by weekday.
;; Each task is a bare id string: the stable identity that done-through history
;; hangs off. Display names live in the Notes file (src/app/seed-notes.md), keyed
;; by id, and are joined on at the Core boundary — never sourced here.
;; An id appears at most once within a day; the same id recurs across days.
;; Weekly tasks are duplicated across both weeks (no shared :weekly section).
{:digital
 {:week-odd
  {:monday    ["gmail"]
   :tuesday   ["todoist"]
   :wednesday ["downloads" "desktop"]
   :thursday  ["gmail"]
   :sunday    ["calendar" "waiting"]}

  :week-even
  {:monday    ["gmail"]
   :tuesday   ["physical-inbox"]
   :wednesday ["photo-inbox" "screenshots"]
   :thursday  ["gmail"]
   :friday    ["tabs"]
   :sunday    ["calendar" "waiting"]}}

 :household
 {:week-odd
  {:monday    ["bathroom"]
   :thursday  ["dust"]
   :sunday    ["towels"]}

  :week-even
  {:wednesday ["vacuum"]
   :sunday    ["towels"]}}}
